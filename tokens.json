{
  "$meta": {
    "name": "Sunlight Design System",
    "source": "https://www.sunlightapi.com/",
    "version": "1.0.0",
    "description": "Design tokens extracted from the Sunlight (sunlightapi.com) brand. Stack-neutral.",
    "typeface": "Figtree"
  },
  "color": {
    "brand": {
      "DEFAULT": "#FFD503",
      "hover": "#F0C800",
      "active": "#E0BB00",
      "soft": "#FFF3B8",
      "subtle": "#FFFBEB"
    },
    "plum": {
      "DEFAULT": "#540F28",
      "hover": "#6B1434"
    },
    "ink": {
      "DEFAULT": "#0C0A08",
      "strong": "#000000"
    },
    "text": {
      "muted": "#435366",
      "subtle": "#79797E",
      "onBrand": "#0C0A08",
      "onDark": "#DBDAC9",
      "inverse": "#FFFFFF"
    },
    "surface": {
      "bg": "#FFFFFF",
      "raised": "#FAFAFA",
      "sand": "#F4F2F0",
      "warm": "#FAFAF8",
      "cool": "#F5F5F7",
      "dark": "#2E2E2E"
    },
    "border": {
      "DEFAULT": "#E9E8E7",
      "strong": "#D6D3D1",
      "ring": "#A8A29E"
    },
    "status": {
      "success": "#4F9D69",
      "danger": "#DC4C3E",
      "info": "#3B82F6"
    }
  },
  "font": {
    "family": {
      "sans": "Figtree, -apple-system, system-ui, 'Segoe UI', Roboto, sans-serif",
      "mono": "'JetBrains Mono', 'SF Mono', ui-monospace, Menlo, Consolas, monospace"
    },
    "size": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "20px",
      "xl": "24px",
      "2xl": "30px",
      "3xl": "36px",
      "4xl": "48px",
      "5xl": "60px"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.0,
      "snug": 1.1,
      "normal": 1.4,
      "relaxed": 1.5
    },
    "tracking": {
      "tighter": "-1.5px",
      "tight": "-0.9px",
      "normal": "0"
    }
  },
  "space": {
    "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px",
    "16": "64px", "20": "80px", "24": "96px", "32": "128px"
  },
  "radius": {
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "24px",
    "3xl": "32px",
    "pill": "9999px"
  },
  "shadow": {
    "xs": "0 1px 2px rgba(12,10,8,0.05)",
    "sm": "0 1px 3px rgba(12,10,8,0.08), 0 1px 2px rgba(12,10,8,0.04)",
    "md": "0 4px 12px rgba(12,10,8,0.08)",
    "lg": "0 12px 32px rgba(12,10,8,0.10)",
    "brand": "0 8px 24px rgba(255,213,3,0.35)"
  },
  "motion": {
    "ease": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easeOut": "cubic-bezier(0.16, 1, 0.3, 1)",
    "duration": { "fast": "150ms", "base": "250ms", "slow": "400ms" }
  },
  "layout": {
    "container": "1200px",
    "containerNarrow": "760px"
  }
}
